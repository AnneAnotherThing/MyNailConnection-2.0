# ---- MNC .gitignore ----
# Keep the repo focused on source — skip derived, regenerated, and local-only stuff.

# npm dependencies (reinstallable from package.json)
node_modules/

# Capacitor's sync target — regenerated from the web source on every build
www/

# Android build artifacts — regenerated
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/app/release/
*.apk
*.aab

# Old deploy zips + scratch files — keep on disk, don't version
archive/

# macOS / Windows junk
.DS_Store
Thumbs.db

# Editor / IDE local settings
.vscode/
.idea/
*.swp
*.swo

# Env files — if you ever add any, don't ship secrets to git
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
