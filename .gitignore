# ---- MNC .gitignore ----
# Keep the repo focused on source — skip derived, regenerated, and local-only stuff.

# npm dependencies (reinstallable from package.json)
node_modules/

# Capacitor's sync target — regenerated from the web source on every build
www/

# Android build artifacts — regenerated
android/build/
android/app/build/
android/.gradle/
android/local.properties
android/app/release/
*.apk
*.aab

# Old deploy zips + scratch files — keep on disk, don't version
archive/

# macOS / Windows junk
.DS_Store
Thumbs.db

# Editor / IDE local settings
.vscode/
.idea/
*.swp
*.swo

# Env files — if you ever add any, don't ship secrets to git
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Android signing — NEVER commit. Keystore = private signing key. Loss = compromised app identity.
*.jks
*.keystore
upload_certificate.pem
upload_certificate.crt
*.p8
*.p12

# iOS code-signing intermediates — never commit
*.csr
*.key
*.cer
*.p12
*.mobileprovision

# All iOS code-signing artifacts (CSRs, keys, certs, profiles, decoded plists)
signing/
