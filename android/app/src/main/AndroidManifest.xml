<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- ─────────────────────────────────────────────────────────
                 App Links — lets auth-email links (Supabase confirm /
                 reset / magic-link URLs routed through mynailconnection.com)
                 open the installed app instead of the browser.

                 Requires /.well-known/assetlinks.json served from
                 https://mynailconnection.com/.well-known/assetlinks.json
                 with this app's SHA-256 fingerprint (see assetlinks.json
                 in the repo root). Without that file, autoVerify fails
                 silently and the link opens in the browser. — 2026-04-23
            ───────────────────────────────────────────────────────── -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" />
                <data android:host="mynailconnection.com" />
                <data android:pathPrefix="/app" />
            </intent-filter>

            <!-- Custom URL scheme fallback (matches strings.xml
                 custom_url_scheme). Useful for any
                 com.mynailconnection.app://… redirect we wire later. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="@string/custom_url_scheme" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Android 13+ (API 33+) requires runtime permission for
         notifications. Capacitor push plugin registers the FCM service
         but doesn't declare this — the host app has to. Without it,
         requestPermissions() will resolve 'denied' silently on
         Android 13+. — 2026-04-23 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
</manifest>
