<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>My Nail Connection</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>My Nail Connection needs access to your camera so you can capture nail photos to upload to your portfolio or post to the feed.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>My Nail Connection needs access to your photo library so you can choose nail photos to upload to your portfolio or post to the feed.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>My Nail Connection saves nail photos you take in-app to your photo library so you have your own copy.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>My Nail Connection uses your location to show nail techs near you and filter the home feed by distance.</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<!-- Encryption export compliance — declares that MNC uses no
	     non-exempt encryption. The app uses only HTTPS (TLS) which is
	     exempt under US export regulations §740.17(b)(3)(i). Setting
	     this to <false/> bypasses Apple's per-build export-compliance
	     question in App Store Connect on every submission.
	     Reference: https://developer.apple.com/documentation/security/complying_with_encryption_export_regulations
	     2026-04-30 -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
